  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Rx.Kql" Version="3.5.3" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
    <PackageReference Include="Tx.Windows" Version="3.0.6" />
  </ItemGroup>

</Project>
